<Window x:Class="AppMapper.Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        xmlns:views="clr-namespace:AppMapper.Controller.Views"
        Title="AppMapper"
        Width="520" Height="720" MinWidth="440" MinHeight="560"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Loaded="OnLoaded"
        Closing="OnClosing">
    <Grid>
        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           OpenPaneLength="96"
                           CompactPaneLength="44"
                           IsPaneToggleVisible="True"
                           IsBackButtonVisible="Collapsed"
                           PaneOpened="OnPaneOpened"
                           PaneClosed="OnPaneClosed">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="配对" TargetPageType="{x:Type views:PairingPage}" NavigationCacheMode="Required">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="QrCode24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="日志" TargetPageType="{x:Type views:LogsPage}" NavigationCacheMode="Required">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Document24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="设置" TargetPageType="{x:Type views:SettingsPage}" NavigationCacheMode="Required">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <tray:NotifyIcon x:Name="TrayIcon"
                         FocusOnLeftClick="True"
                         MenuOnRightClick="True"
                         TooltipText="AppMapper"
                         LeftDoubleClick="OnTrayDoubleClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="OnShowMainWindow" />
                    <Separator />
                    <MenuItem Header="退出" Click="OnExit" />
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</Window>
