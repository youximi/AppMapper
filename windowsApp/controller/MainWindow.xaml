<Window x:Class="AppMapper.Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppMapper" Height="680" Width="980"
        MinHeight="560" MinWidth="840">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="AppMapper" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="配对" Margin="0,24,0,8" FontSize="18" FontWeight="SemiBold" />

            <Border BorderBrush="#DDDDDD" BorderThickness="1" Padding="12" CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="{Binding ServerAddress}" FontSize="14" />
                    <TextBlock Text="{Binding PairingCode}" FontSize="40" FontWeight="Bold" Margin="0,8,0,8" />
                    <Image Source="{Binding QrImage}" Width="220" Height="220" Stretch="Uniform" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding PairingUri}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#555555" />
                </StackPanel>
            </Border>

            <TextBlock Text="设置" Margin="0,24,0,8" FontSize="18" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="端口" VerticalAlignment="Center" Width="56" />
                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="96" />
                <Button Content="重启服务" Command="{Binding RestartServerCommand}" Margin="8,0,0,0" />
            </StackPanel>
            <CheckBox Content="用户关闭映射窗口后自动重开"
                      IsChecked="{Binding RelaunchMapperWhenClosed}"
                      Margin="0,12,0,0" />
            <Button Content="打开 apps 目录" Command="{Binding OpenAppsDirectoryCommand}" Margin="0,12,0,0" />
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="160" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding CurrentStatus}" FontSize="18" FontWeight="SemiBold" />

            <DataGrid Grid.Row="1" ItemsSource="{Binding Devices}" AutoGenerateColumns="False" Margin="0,12,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="设备" Binding="{Binding DeviceName}" Width="*" />
                    <DataGridTextColumn Header="ID" Binding="{Binding DeviceId}" Width="180" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="100" />
                    <DataGridTextColumn Header="当前 App" Binding="{Binding CurrentApp}" Width="160" />
                    <DataGridTextColumn Header="最后消息" Binding="{Binding LastSeen}" Width="160" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2" Text="日志" FontSize="18" FontWeight="SemiBold" />
            <ListBox Grid.Row="3" ItemsSource="{Binding Logs}" Margin="0,8,0,0" />
        </Grid>
    </Grid>
</Window>
