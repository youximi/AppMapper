<Page x:Class="AppMapper.Controller.Views.PairingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="配对"
      ScrollViewer.CanContentScroll="True">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="24,24,24,24">
            <TextBlock Text="配对" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,16" />

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <StackPanel>
                    <TextBlock Text="本机地址" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding ServerAddress}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,16" />
                    <TextBlock Text="{Binding NetworkWarning}"
                               TextWrapping="Wrap"
                               Foreground="#9A6700"
                               Visibility="{Binding HasNetworkWarning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Margin="0,-8,0,16" />

                    <TextBlock Text="配对验证码（每 60 秒刷新）" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding PairingCode}" FontSize="48" FontWeight="Bold" Margin="0,4,0,16" />

                    <Border Background="White" CornerRadius="6" Padding="8" HorizontalAlignment="Left">
                        <Image Source="{Binding QrImage}" Width="220" Height="220" Stretch="Uniform" />
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="设备" FontSize="20" FontWeight="SemiBold" Margin="0,24,0,12" />

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ListView ItemsSource="{Binding Devices}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="设备" DisplayMemberBinding="{Binding DeviceName}" Width="140" />
                            <GridViewColumn Header="ID" DisplayMemberBinding="{Binding DeviceId}" Width="180" />
                            <GridViewColumn Header="状态" DisplayMemberBinding="{Binding State}" Width="120" />
                            <GridViewColumn Header="当前 App" DisplayMemberBinding="{Binding CurrentApp}" Width="160" />
                            <GridViewColumn Header="最后消息" DisplayMemberBinding="{Binding LastSeen, StringFormat=\{0:HH:mm:ss\}}" Width="100" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
